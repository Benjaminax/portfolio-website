# Backend API
PORT=5000

# MongoDB Atlas connection string
# Example: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI=
MONGODB_DB_NAME=portfolio

# SMTP settings for sending email notifications
# Example for Gmail: smtp.gmail.com, port 587, and an app password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Email routing
NOTIFY_EMAIL_TO=kojoben29@gmail.com
NOTIFY_EMAIL_FROM=
